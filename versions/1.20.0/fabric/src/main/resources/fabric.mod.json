{
  "schemaVersion": 1,
  "id": "enthusia_autoclicker",
  "version": "${version}",
  "name": "Enthusia AutoClicker",
  "description": "A rate-limited client auto-clicker designed for use on Enthusia.",
  "authors": [
    "P2wn"
  ],
  "license": "All-Rights-Reserved",
  "icon": "assets/enthusia_autoclicker/icon.png",
  "environment": "client",
  "entrypoints": {
    "client": [
      "net.enthusia.autoclicker.fabric.EnthusiaAutoClickerFabric"
    ],
    "modmenu": [
      "net.enthusia.autoclicker.fabric.EnthusiaAutoClickerModMenu"
    ]
  },
  "depends": {
